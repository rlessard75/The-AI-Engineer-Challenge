# Copy to `.env.local` and adjust as needed.

# Server-side only: where Next.js proxies POST /api/chat (no trailing slash).
# Default when unset: http://127.0.0.1:8000
# BACKEND_URL=http://127.0.0.1:8000

# Optional: make the browser call the API directly instead of using the proxy.
# Use only when you need cross-origin calls and the URL is reachable from the page
# (same scheme as the site, or http with http localhost dev).
# NEXT_PUBLIC_API_BASE_URL=https://your-api.example.com
